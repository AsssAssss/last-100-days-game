{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://last-100-days-api.2518486059.workers.dev/:path*"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}
