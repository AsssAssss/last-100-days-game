# Copy to .env.local

# 后端 API 基地址（用户系统 + 存档）
# 本地开发：http://127.0.0.1:8787（跑 wrangler dev）
# 生产：https://last-100-days-api.<your-account>.workers.dev
VITE_BACKEND_URL=http://127.0.0.1:8787

# LLM 配置的默认值（玩家在 UI 里仍可改）
# 第一次进游戏会弹出 LLM 设置屏，玩家填自己的 key，base URL/model 默认这两个值。
VITE_LLM_DEFAULT_BASE_URL=https://onehub.akacm.com/claude
VITE_LLM_DEFAULT_MODEL=claude-sonnet-4-6
