# Copy this file to .env.local and fill in your values.
# Vite exposes any var prefixed with VITE_ to the browser bundle.
# WARNING: this game is designed for self-play. Do not deploy with a real key
# embedded in the frontend bundle — anyone who opens devtools can read it.

# Your Anthropic API key, OR your one-hub / openrouter / 其他代理 key
VITE_ANTHROPIC_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model name. 真实 Anthropic 用 claude-sonnet-4-6 / claude-opus-4-7。
# one-hub 等代理可能要求其他别名（如 claude-3-5-sonnet-20241022），按你渠道的规定填。
VITE_ANTHROPIC_MODEL=claude-sonnet-4-6

# 可选：自定义 base URL。
# 用 Anthropic 官方 API 时留空即可。
# 用 one-hub / Cloudflare AI Gateway / OpenRouter 的 Anthropic 兼容端点时，
# 填上代理域名，例如：https://your-onehub.example.com
# VITE_ANTHROPIC_BASE_URL=https://your-onehub.example.com
